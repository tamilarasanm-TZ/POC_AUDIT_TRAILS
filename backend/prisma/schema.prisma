generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders     Order[]
  auditLogs  AuditLog[]
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  product   String
  quantity  Int
  amount    Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  requestId  String?
  userId     String?
  userEmail  String?
  action     String
  entity     String?
  entityId   String?
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  httpMethod String?
  url        String?
  statusCode Int?
  prevHash   String?
  hash       String
  timestamp  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([timestamp])
}
